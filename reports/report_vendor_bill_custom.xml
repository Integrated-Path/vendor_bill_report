                        <div>
                            <strong>Date from: </strong>
                            <span t-field="wizard.date_from" />
                        </div>
                        <div>
                            <strong>To: </strong>
                            <span t-field="wizard.date_to" />
                        </div>
                    </div>
                    <table class="table table-sm table-bordered"
                        style="width:100%; border-spacing: 0; table-layout:auto; border-collapse:collapse;">
                        <!-- <colgroup>
                            <col style="width:8%" />
                            <col style="width:20%" />
                            <col style="width:15%" />
                            <col style="width:30%" />
