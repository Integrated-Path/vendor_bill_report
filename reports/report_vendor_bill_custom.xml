                        </colgroup> -->
                        <t t-set="amount_total" t-value="0" />
                        <thead>
                            <tr>
                                <th class="text-center"
                                    style="font-weight:bold; white-space: nowrap;">No.</th>

                                <th class="text-center"
                                    style="font-weight:bold; white-space: nowrap;">Date</th>

                                <th class="text-center"
                                    style="font-weight:bold; white-space: nowrap;">Amount</th>

                                <th class="text-center" style="font-weight:bold;">Label</th>

                                <th class="text-center" style="font-weight:bold;">Notes</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="line_counter" t-value="1" />
                            <t t-foreach="docs" t-as="bill">
                                <t t-foreach="bill.invoice_line_ids" t-as="line">
                                    <t t-set="amount_total"
                                        t-value="amount_total + line.price_subtotal" />
                                    <tr>
                                        <td class="text-center">
                                            <span t-esc="line_counter" />
                                        </td>
                                        <td class="text-center">
                                            <span t-field="bill.invoice_date" />
                                        </td>
                                        <td class="text-center">
                                            <span t-field="line.price_subtotal" />
                                        </td>
                                        <td class="text-center">
                                            <span t-field="line.name" />
                                        </td>
                                        <td class="text-center">
                                            <span t-field="bill.ref" />
                                        </td>
                                    </tr>
                                    <t t-set="line_counter" t-value="line_counter + 1" />
                                </t>
                            </t>
                        </tbody>
                        <!-- <tfoot>
