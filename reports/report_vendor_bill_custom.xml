                    </table>
                    <div>
                        <table class="table table-sm table-bordered"
                            style="width:50%; border-spacing: 0; table-layout:auto; border-collapse:collapse;">
                            <tfoot>
                                <tr>
                                    <td class="text-center" colspan="1"
                                        style="font-weight:bold; white-space:nowrap;">
                                        Total
                                    </td>

                                    <td class="text-center">
                                        <span t-esc="amount_total" />
                                    </td>
                                </tr>

                                <t
                                    t-if="wizard.analytic_account_id and any(bill.is_cost_plus for bill in docs)">
                                    <tr>
                                        <td class="text-center" colspan="1"
                                            style="font-weight:bold;">commission <span
                                                t-esc="wizard.analytic_account_id.markup_percentage * 100" />
                                            % </td>

                                        <td class="text-center">
                                            <span
                                                t-esc="amount_total * wizard.analytic_account_id.markup_percentage" />
                                        </td>
                                    </tr>
                                </t>

                                <tr>
                                    <td class="text-center" colspan="1"
                                        style="font-weight:bold; background-color:#ffffcc;">
                                        Grand Total
                                    </td>

                                    <td class="text-center">
                                        <span
                                            t-esc="amount_total + (amount_total * wizard.analytic_account_id.markup_percentage)" />
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </t>
        </t>
    </template>
